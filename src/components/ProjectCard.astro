---
// ProjectCard Component
// Displays a single project with title, description, tags, and links

interface Props {
  /** Project title */
  title: string;
  /** Project description */
  description: string;
  /** Array of tags/categories */
  tags: string[];
  /** Optional external URL to the project */
  url?: string;
  /** Optional GitHub repository URL */
  github?: string;
  /** Whether this is a featured project */
  featured?: boolean;
}

// Destructure props with default value for featured
const { title, description, tags, url, github, featured = false } = Astro.props;
---

<article
  class:list={[
    'group relative p-6 rounded-xl border transition-all duration-300',
    featured
      ? 'bg-surface border-border hover:border-muted'
      : 'bg-transparent border-border hover:bg-surface hover:border-muted',
  ]}
>
  {/* Featured Badge */}
  {featured && (
    <span class="inline-block px-3 py-1 text-xs font-semibold text-text bg-border rounded-full mb-4">
      Featured
    </span>
  )}

  {/* Title */}
  <h3 class="text-xl font-semibold text-text mb-2 group-hover:text-muted transition-colors">
    {url ? (
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        class="hover:underline decoration-muted/50"
      >
        {title}
      </a>
    ) : (
      <span>{title}</span>
    )}
  </h3>

  {/* Description */}
  <p class="text-muted text-sm mb-4 leading-relaxed line-clamp-3">
    {description}
  </p>

  {/* Tags */}
  <div class="flex flex-wrap gap-2 mb-4">
    {tags.map((tag) => (
      <span class="px-2 py-1 text-xs font-medium text-muted bg-background border border-border rounded">
        {tag}
      </span>
    ))}
  </div>

  {/* Action Links */}
  <div class="flex items-center gap-4 pt-2 border-t border-border/50">
    {url && (
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1 text-sm font-medium text-muted hover:text-text transition-colors"
      >
        <span>Visit</span>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    )}
    {github && (
      <a
        href={github}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1 text-sm font-medium text-muted hover:text-text transition-colors"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
        </svg>
        <span>GitHub</span>
      </a>
    )}
  </div>
</article>
