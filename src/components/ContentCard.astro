---
// ContentCard Component - Display blog post / note summary
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  tags: string[];
}

const { title, description, pubDate, slug, tags } = Astro.props;

// Format date nicely
const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="group p-6 rounded-xl border border-border hover:border-muted transition-all duration-300">
  <!-- Date -->
  <time class="text-xs text-muted mb-2 block">{formattedDate}</time>

  <!-- Title -->
  <h3 class="text-lg font-semibold text-text mb-2 group-hover:text-muted transition-colors">
    <a href={`/content/${slug}`}>
      {title}
    </a>
  </h3>

  <!-- Description -->
  <p class="text-sm text-muted mb-4 leading-relaxed">
    {description}
  </p>

  <!-- Tags -->
  <div class="flex flex-wrap gap-2 mb-2">
    {tags.map((tag) => (
      <span class="px-2 py-1 text-xs font-medium text-muted bg-background rounded">
        {tag}
      </span>
    ))}
  </div>

  <!-- Read more -->
  <a
    href={`/content/${slug}`}
    class="text-sm font-medium text-muted hover:text-text transition-colors"
  >
    Read more &rarr;
  </a>
</article>
