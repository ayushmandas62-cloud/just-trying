---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/ProjectCard.astro';

// Featured projects data
const featuredProjects = [
  {
  title: "For You (Water Distribution Business)",
  description: "Designed a scalable website for a water distribution service connecting suppliers with local businesses.",
  tags: ["Business", "Logistics"],
  url: "#",
  featured: true,
  },
  {
  title: "Rice Bowl Guwahati (Restaurant Website)",
  description: "Built a conversion-focused restaurant website with WhatsApp ordering to increase direct orders and reduce dependency on food delivery apps.",
  tags: ["Business","Restaurant"],
  url: "#",
  featured: true,
  },
  {
  title: "PowerFit Gym (Landing Page)",
  description: "Created a high-converting landing page for a gym to increase membership signups.",
  tags: ["Fitness", "Marketing"],
  url: "#",
  featured: true,
  },
  {
  title: "Grand Stay Hotel (Website)",
  description: "Designed a premium hotel website with booking-focused UI to increase direct reservations.",
  tags: ["Hospitality", "Business"],
  url: "/hotel",
  featured: true,
  },
  {
  title: "CareClinic (Healthcare Website)",
  description: "High-converting clinic website template with click animations, booking forms, and premium UI.",
  tags: ["Healthcare", "Business"],
  url: "/clinic",
  featured: true,
  },
];
---

<Layout title="Ayushman - Business, AI, Marketing, Startups">
  <Navbar />

  <main class="flex-1">
    <!-- Hero Section -->
    <section class="max-w-4xl mx-auto px-6 py-20 md:py-32">
      <div class="space-y-6">
        <!-- Intro label -->
        <p class="text-muted text-sm font-medium tracking-wide uppercase">
          Hello, I'm
        </p>

        <!-- Name -->
        <h1 class="text-4xl md:text-6xl font-bold text-text animate-fadeUp">
          Ayushman
        </h1>

        <!-- Tagline -->
        <p class="text-xl md:text-2xl text-muted max-w-2xl leading-relaxed animate-fadeUp">
          I design high-converting websites that help businesses get more customers and increase sales.
        </p>

        <!-- Short bio -->
        <p class="text-muted max-w-xl leading-relaxed">
          I create modern, fast, and conversion-focused websites for restaurants, gyms, hotels, and local businesses.
        </p>

        <!-- CTA buttons -->
        <div class="flex flex-wrap gap-4 pt-4">
          <a
            href="/projects"
            class="px-6 py-3 bg-text text-background font-medium rounded-lg hover:bg-muted transition-colors"
          >
            View My Work
          </a>
          <a
            href="/about"
            class="px-6 py-3 border border-border text-text font-medium rounded-lg hover:border-muted transition-colors"
          >
            Start Your Website
          </a>
        </div>
      </div>
    </section>

    <!-- Featured Projects Section -->
    <section class="max-w-4xl mx-auto px-6 py-20 text-center">
  
    <h2 class="text-3xl font-bold mb-4">
    Get More Customers With Your Website🚀
    </h2>

    <p class="text-zinc-400 mb-8">
    Want more customers for your business? I design websites that convert visitors into paying clients.
    </p>

    <div class="flex justify-center gap-4 flex-wrap">
    
    <a href="https://wa.me/918473819569" target="_blank"
       class="bg-green-500 text-black px-6 py-3 rounded-lg font-medium hover:bg-green-400 transition">
      Start Project on WhatsApp
    </a>

    <a href="mailto:ayushmandas62@gmail.com"
       class="border border-zinc-600 px-6 py-3 rounded-lg hover:border-zinc-400 transition">
      Email Me
    </a>

    </div>

    </section>

    <!-- Quick Links Section -->
    <section class="max-w-4xl mx-auto px-6 py-16 border-t border-border">
      <div class="grid gap-6 md:grid-cols-3">
        <!-- Content link -->
        <a
          href="/content"
          class="p-6 rounded-xl border border-border hover:border-muted transition-all group"
        >
          <h3 class="text-lg font-semibold text-text mb-2 group-hover:text-muted transition-colors">
            Client Projects 
          </h3>
          <p class="text-sm text-muted">
           Real website projects designed to help businesses get more customers.
          </p>
        </a>

        <!-- About link -->
        <a
          href="/about"
          class="p-6 rounded-xl border border-border hover:border-muted transition-all group"
        >
          <h3 class="text-lg font-semibold text-text mb-2 group-hover:text-muted transition-colors">
            About
          </h3>
          <p class="text-sm text-muted">
            Learn more about my background, skills, and experience.
          </p>
        </a>

        <!-- Contact link -->
        <a
          href="/contact"
          class="p-6 rounded-xl border border-border hover:border-muted transition-all group"
        >
          <h3 class="text-lg font-semibold text-text mb-2 group-hover:text-muted transition-colors">
            Get in Touch
          </h3>
          <p class="text-sm text-muted">
            Connect with me on social media or send an email.
          </p>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
