---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

// Social links
const socialLinks = [
  {
    name: 'Twitter',
    url: 'https://twitter.com/ayushman',
    username: '@ayushman',
    description: 'Follow for thoughts on business, AI, and marketing',
  },
  {
    name: 'GitHub',
    url: 'https://github.com/ayushman',
    username: 'ayushman',
    description: 'Check out my projects and experiments',
  },
  {
    name: 'LinkedIn',
    url: 'https://linkedin.com/in/ayushman',
    username: 'Ayushman',
    description: 'Connect professionally',
  },
  {
    name: 'Email',
    url: 'mailto:hello@ayushman.dev',
    username: 'hello@ayushman.dev',
    description: 'For business inquiries and collaborations',
  },
];
---

<Layout
  title="Contact - Ayushman"
  description="Get in touch with Ayushman for collaborations, business inquiries, or just to say hello."
>
  <Navbar />

  <main class="flex-1">
    <!-- Page Header -->
    <section class="max-w-4xl mx-auto px-6 py-20 border-b border-border">
      <h1 class="text-4xl font-bold text-text mb-4">Contact</h1>
      <p class="text-muted text-lg max-w-2xl">
        I'd love to hear from you. Whether it's about a project, collaboration,
        or just saying hello - feel free to reach out.
      </p>
    </section>

    <!-- Contact Content -->
    <section class="max-w-4xl mx-auto px-6 py-16">
      <div class="grid gap-8 md:grid-cols-2">
        <!-- Social Links -->
        <div>
          <h2 class="text-xl font-semibold text-text mb-6">Connect With Me</h2>
          <div class="space-y-4">
            {socialLinks.map((social) => (
              <a
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
                class="block p-4 rounded-xl border border-border hover:border-muted transition-all group"
              >
                <div class="flex items-center justify-between mb-1">
                  <h3 class="font-medium text-text group-hover:text-muted transition-colors">
                    {social.name}
                  </h3>
                  <span class="text-muted text-sm">{social.username}</span>
                </div>
                <p class="text-sm text-muted">{social.description}</p>
              </a>
            ))}
          </div>
        </div>

        <!-- Contact Form Placeholder -->
        <div>
          <h2 class="text-xl font-semibold text-text mb-6">Send a Message</h2>
          <form class="space-y-4" action="#" method="POST">
            <div>
              <label for="name" class="block text-sm font-medium text-muted mb-2">
                Name
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 bg-surface border border-border rounded-lg text-text placeholder-muted/50 focus:outline-none focus:border-muted transition-colors"
                placeholder="Your name"
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-muted mb-2">
                Email
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 bg-surface border border-border rounded-lg text-text placeholder-muted/50 focus:outline-none focus:border-muted transition-colors"
                placeholder="your@email.com"
              />
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-muted mb-2">
                Message
              </label>
              <textarea
                id="message"
                name="message"
                rows="4"
                required
                class="w-full px-4 py-3 bg-surface border border-border rounded-lg text-text placeholder-muted/50 focus:outline-none focus:border-muted transition-colors resize-none"
                placeholder="Your message..."
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full px-6 py-3 bg-text text-background font-medium rounded-lg hover:bg-muted transition-colors"
            >
              Send Message
            </button>
          </form>
        </div>
      </div>
    </section>

    <!-- FAQ / Info -->
    <section class="max-w-4xl mx-auto px-6 py-16 border-t border-border">
      <h2 class="text-xl font-semibold text-text mb-6">What I'm Interested In</h2>
      <div class="grid gap-4 md:grid-cols-2">
        <div class="p-4 rounded-lg bg-surface border border-border">
          <h3 class="font-medium text-text mb-2">Collaborations</h3>
          <p class="text-sm text-muted">
            Open to discussing joint ventures, partnerships, and collaborative projects.
          </p>
        </div>
        <div class="p-4 rounded-lg bg-surface border border-border">
          <h3 class="font-medium text-text mb-2">Business Inquiries</h3>
          <p class="text-sm text-muted">
            Interested in consulting, advisory roles, or business development opportunities.
          </p>
        </div>
        <div class="p-4 rounded-lg bg-surface border border-border">
          <h3 class="font-medium text-text mb-2">AI & Tech</h3>
          <p class="text-sm text-muted">
            Always interested in discussing AI tools, automation, and technology trends.
          </p>
        </div>
        <div class="p-4 rounded-lg bg-surface border border-border">
          <h3 class="font-medium text-text mb-2">Just Saying Hi</h3>
          <p class="text-sm text-muted">
            Happy to connect with interesting people even without a specific agenda.
          </p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
