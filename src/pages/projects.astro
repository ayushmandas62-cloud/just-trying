---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/ProjectCard.astro';

// All projects data
const projects = [

  {
    title: "Rice Bowl Guwahati (Restaurant Website)",
    description: "Designed a conversion-focused restaurant website with WhatsApp ordering to increase direct orders and reduce dependency on food delivery apps.",
    tags: ["Restaurant", "Business"],
    url: "/restaurant",
  },
  {
    title: "For You (Water Distribution Website)",
    description: "Built a website for a water distribution business to attract local clients and generate inquiries through clear service positioning.",
    tags: ["Business", "Logistics"],
    url: "/waterdistribution",
  },
  {
    title: "PowerFit Gym (Landing Page)",
    description: "Created a high-converting landing page for a gym to increase membership signups using strong CTAs and WhatsApp leads.",
    tags: ["Fitness", "Marketing"],
    url: "/gym",
  },
  {
    title: "Grand Stay Hotel (Website)",
    description: "Designed a premium hotel website focused on increasing direct bookings and reducing reliance on third-party platforms.",
    tags: ["Hospitality", "Business"],
    url: "/hotel",
  },
  ];
 ---

<Layout
  title="Projects - Ayushman"
  description="Explore my projects in business, AI, marketing, and technology."
>
  <Navbar />

  <main class="flex-1">
    <!-- Page Header -->
    <section class="max-w-4xl mx-auto px-6 py-20 border-b border-border">
      <h1 class="text-4xl font-bold text-text mb-4">Projects</h1>
      <p class="text-muted text-lg max-w-2xl">
        A selection of high-converting websites designed for businesses to attract more customers and increase revenue.
      </p>
    </section>

    <!-- Projects Grid -->
    <section class="max-w-4xl mx-auto px-6 py-16">
      <!-- Featured Projects -->
      <div class="mb-16">
        <h2 class="text-xl font-semibold text-text mb-6">Featured</h2>
        <div class="grid gap-6 md:grid-cols-2">
          {projects
            .filter((p) => p.featured)
            .map((project) => (
              <ProjectCard {...project} />
            ))}
        </div>
      </div>

      <!-- Other Projects -->
      <div>
        <h2 class="text-xl font-semibold text-text mb-6">Other Projects</h2>
        <div class="grid gap-6 md:grid-cols-2">
          {projects
            .filter((p) => !p.featured)
            .map((project) => (
              <ProjectCard {...project} />
            ))}
        </div>
      </div>
    </section>

    <!-- Call to Action -->
    <section class="max-w-4xl mx-auto px-6 py-16 border-t border-border">
      <div class="text-center">
        <p class="text-muted mb-4">Interested in collaborating?</p>
        <a
          href="/contact"
          class="inline-block px-6 py-3 bg-text text-background font-medium rounded-lg hover:bg-muted transition-colors"
        >
          Get in Touch
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
