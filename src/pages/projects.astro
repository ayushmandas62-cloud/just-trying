---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/ProjectCard.astro';

// All projects data
const projects = [
  {
    title: 'Water Distribution Business',
    description: 'A scalable water delivery service connecting rural communities with clean water suppliers. Implemented route optimization and inventory management systems.',
    tags: ['Business', 'Logistics', 'Community'],
    url: '#',
    featured: true,
  },
  {
    title: 'AI Automation Tools',
    description: 'Custom AI solutions for small businesses to automate repetitive tasks. Includes chatbots, data processing pipelines, and workflow automation.',
    tags: ['AI', 'Automation', 'SaaS'],
    url: '#',
    featured: true,
  },
  {
    title: 'Local Business Marketing',
    description: 'Experimenting with grassroots marketing strategies for local businesses. Testing combinations of social media, SEO, and community outreach programs.',
    tags: ['Marketing', 'Local SEO', 'Experiments'],
    url: '#',
    featured: true,
  },
  {
    title: 'E-commerce Platform',
    description: 'Built a modern e-commerce solution for a local retailer. Features include inventory management, order tracking, and payment integration.',
    tags: ['E-commerce', 'Web Dev', 'Retail'],
    url: '#',
    featured: false,
  },
  {
    title: 'Data Analytics Dashboard',
    description: 'Created a custom analytics dashboard for tracking marketing campaign performance. Visualizes metrics from multiple advertising platforms.',
    tags: ['Analytics', 'Data Viz', 'Marketing'],
    url: '#',
    featured: false,
  },
  {
    title: 'Content Management System',
    description: 'Developed a lightweight CMS for bloggers and content creators. Focus on simplicity, speed, and SEO optimization.',
    tags: ['CMS', 'Web Dev', 'Content'],
    url: '#',
    featured: false,
  },
];
---

<Layout
  title="Projects - Ayushman"
  description="Explore my projects in business, AI, marketing, and technology."
>
  <Navbar />

  <main class="flex-1">
    <!-- Page Header -->
    <section class="max-w-4xl mx-auto px-6 py-20 border-b border-border">
      <h1 class="text-4xl font-bold text-text mb-4">Projects</h1>
      <p class="text-muted text-lg max-w-2xl">
        A collection of my work spanning business ventures, AI tools,
        marketing experiments, and technical projects.
      </p>
    </section>

    <!-- Projects Grid -->
    <section class="max-w-4xl mx-auto px-6 py-16">
      <!-- Featured Projects -->
      <div class="mb-16">
        <h2 class="text-xl font-semibold text-text mb-6">Featured</h2>
        <div class="grid gap-6 md:grid-cols-2">
          {projects
            .filter((p) => p.featured)
            .map((project) => (
              <ProjectCard {...project} />
            ))}
        </div>
      </div>

      <!-- Other Projects -->
      <div>
        <h2 class="text-xl font-semibold text-text mb-6">Other Projects</h2>
        <div class="grid gap-6 md:grid-cols-2">
          {projects
            .filter((p) => !p.featured)
            .map((project) => (
              <ProjectCard {...project} />
            ))}
        </div>
      </div>
    </section>

    <!-- Call to Action -->
    <section class="max-w-4xl mx-auto px-6 py-16 border-t border-border">
      <div class="text-center">
        <p class="text-muted mb-4">Interested in collaborating?</p>
        <a
          href="/contact"
          class="inline-block px-6 py-3 bg-text text-background font-medium rounded-lg hover:bg-muted transition-colors"
        >
          Get in Touch
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
