---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

// Skills organized by category
const skills = [
  {
    category: 'Business & Marketing',
    items: ['Business Strategy', 'Digital Marketing', 'SEO', 'Content Marketing', 'Analytics'],
  },
  {
    category: 'AI & Technology',
    items: ['AI Tools', 'Automation', 'Prompt Engineering', 'Python', 'No-Code Tools'],
  },
  {
    category: 'Personal',
    items: ['Problem Solving', 'Communication', 'Adaptability', 'Creativity'],
  },
];

// Experience / Timeline
const experience = [
  {
    title: 'Entrepreneur',
    company: 'Self-employed',
    period: '2020 - Present',
    description: 'Building businesses and exploring startup ideas in AI, marketing, and local business optimization.',
  },
  {
    title: 'Marketing Consultant',
    company: 'Local Businesses',
    period: '2018 - 2020',
    description: 'Helped small businesses with digital marketing strategies, local SEO, and online presence.',
  },
  {
    title: 'Freelancer',
    company: 'Various Clients',
    period: '2016 - 2018',
    description: 'Provided digital marketing and web presence services to startups and local businesses.',
  },
];
---

<Layout
  title="About - Ayushman"
  description="Learn more about Ayushman - background, skills, and experience."
>
  <Navbar />

  <main class="flex-1">
    <!-- Page Header -->
    <section class="max-w-4xl mx-auto px-6 py-20 border-b border-border">
      <h1 class="text-4xl font-bold text-text mb-4">About Me</h1>
      <p class="text-muted text-lg max-w-2xl">
        Entrepreneur, marketer, and tech enthusiast exploring the intersection
        of business, AI, and marketing.
      </p>
    </section>

    <!-- Bio Section -->
    <section class="max-w-4xl mx-auto px-6 py-16">
      <div class="max-w-3xl">
        <h2 class="text-2xl font-semibold text-text mb-6">Background</h2>
        <div class="space-y-4 text-muted leading-relaxed">
          <p>
            Hey there! I'm Ayushman, and I've spent the last several years
            exploring the world of business, technology, and marketing.
          </p>
          <p>
            My journey started with helping local businesses improve their
            online presence. This led me to discover the power of digital
            marketing and eventually sparked my interest in AI and automation.
          </p>
          <p>
            Today, I focus on building projects that combine my interests in
            business development, AI tools, and marketing experiments. I
            believe in learning by doing and sharing the journey openly.
          </p>
          <p>
            When I'm not working on projects, you'll find me researching new
            technologies, reading about business strategies, or experimenting
            with different marketing approaches.
          </p>
        </div>
      </div>
    </section>

    <!-- Skills Section -->
    <section class="max-w-4xl mx-auto px-6 py-16 border-t border-border">
      <h2 class="text-2xl font-semibold text-text mb-8">Skills & Focus Areas</h2>
      <div class="grid gap-8 md:grid-cols-3">
        {skills.map((skillGroup) => (
          <div>
            <h3 class="text-lg font-medium text-text mb-4">
              {skillGroup.category}
            </h3>
            <ul class="space-y-2">
              {skillGroup.items.map((skill) => (
                <li class="text-muted text-sm flex items-center gap-2">
                  <span class="w-1.5 h-1.5 bg-text rounded-full"></span>
                  {skill}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- Experience Section -->
    <section class="max-w-4xl mx-auto px-6 py-16 border-t border-border">
      <h2 class="text-2xl font-semibold text-text mb-8">Experience</h2>
      <div class="space-y-8">
        {experience.map((job) => (
          <div class="flex gap-4">
            <!-- Timeline indicator -->
            <div class="flex flex-col items-center">
              <div class="w-3 h-3 bg-text rounded-full"></div>
              <div class="w-px h-full bg-border"></div>
            </div>

            <!-- Content -->
            <div class="pb-8">
              <div class="flex flex-col md:flex-row md:items-center gap-2 mb-2">
                <h3 class="text-lg font-medium text-text">{job.title}</h3>
                <span class="text-muted text-sm">@ {job.company}</span>
              </div>
              <p class="text-sm text-muted mb-2">{job.period}</p>
              <p class="text-muted text-sm leading-relaxed">{job.description}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Interests Section -->
    <section class="max-w-4xl mx-auto px-6 py-16 border-t border-border">
      <h2 class="text-2xl font-semibold text-text mb-6">Interests</h2>
      <div class="flex flex-wrap gap-3">
        {[
          'Startups', 'AI Technology', 'Digital Marketing', 'Business Strategy',
          'Product Development', 'Content Creation', 'E-commerce', 'Local Business',
          'Automation', 'Marketing Experiments', 'SaaS', 'Community Building',
        ].map((interest) => (
          <span class="px-4 py-2 bg-surface border border-border rounded-full text-sm text-muted">
            {interest}
          </span>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="max-w-4xl mx-auto px-6 py-16 border-t border-border">
      <div class="text-center">
        <p class="text-muted mb-4">Want to connect?</p>
        <a
          href="/contact"
          class="inline-block px-6 py-3 bg-text text-background font-medium rounded-lg hover:bg-muted transition-colors"
        >
          Get in Touch
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
