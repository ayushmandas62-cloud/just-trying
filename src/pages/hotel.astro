---
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Grand Stay Hotel</title>
  </head>

  <body class="bg-black text-white">

    <!-- HERO -->
    <section class="min-h-screen flex flex-col justify-center items-center text-center px-6 relative">

      <!-- Glow -->
      <div class="absolute w-72 h-72 bg-yellow-500/20 blur-3xl rounded-full top-20"></div>

      <h1 class="text-5xl md:text-7xl font-bold mb-4">
        Luxury Stay Experience 🏨
      </h1>

      <p class="text-gray-400 max-w-xl mb-6 text-lg">
        Experience comfort, elegance, and premium hospitality at Grand Stay Hotel.
      </p>

      <div class="flex gap-4">
        <a 
          href="https://wa.me/91XXXXXXXXXX"
          class="bg-yellow-500 text-black px-6 py-3 rounded-lg font-semibold hover:bg-yellow-400 transition"
        >
          Book on WhatsApp
        </a>

        <a 
          href="#rooms"
          class="border border-gray-700 px-6 py-3 rounded-lg hover:border-gray-500 transition"
        >
          View Rooms
        </a>
      </div>
    </section>


    <!-- ROOMS -->
    <section id="rooms" class="px-6 py-20 border-t border-gray-800">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">
        Our Rooms
      </h2>

      <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">

        <!-- ROOM -->
        <div class="bg-zinc-900 border border-gray-800 p-6 rounded-2xl hover:scale-105 transition">
          <h3 class="text-xl font-semibold mb-2">Deluxe Room</h3>
          <p class="text-gray-400 mb-3">
            Comfortable room with modern amenities
          </p>
          <p class="text-yellow-400 font-bold text-lg">₹1999 / night</p>
        </div>

        <!-- ROOM -->
        <div class="bg-zinc-900 border border-yellow-500 p-6 rounded-2xl scale-105">
          <h3 class="text-xl font-semibold mb-2">Suite Room</h3>
          <p class="text-gray-400 mb-3">
            Spacious suite with luxury experience
          </p>
          <p class="text-yellow-400 font-bold text-lg">₹2999 / night</p>
        </div>

        <!-- ROOM -->
        <div class="bg-zinc-900 border border-gray-800 p-6 rounded-2xl hover:scale-105 transition">
          <h3 class="text-xl font-semibold mb-2">Family Room</h3>
          <p class="text-gray-400 mb-3">
            Perfect stay for families and groups
          </p>
          <p class="text-yellow-400 font-bold text-lg">₹2499 / night</p>
        </div>

      </div>
    </section>


    <!-- FEATURES -->
    <section class="px-6 py-20 border-t border-gray-800 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-12">
        Why Choose Grand Stay ✨
      </h2>

      <div class="grid md:grid-cols-3 gap-10 max-w-5xl mx-auto">

        <div class="bg-zinc-900 p-6 rounded-xl border border-gray-800">
          <h3 class="font-semibold mb-2 text-lg">🛏️ Comfortable Rooms</h3>
          <p class="text-gray-400">Relax in premium quality beds</p>
        </div>

        <div class="bg-zinc-900 p-6 rounded-xl border border-gray-800">
          <h3 class="font-semibold mb-2 text-lg">📶 Free WiFi</h3>
          <p class="text-gray-400">Stay connected anytime</p>
        </div>

        <div class="bg-zinc-900 p-6 rounded-xl border border-gray-800">
          <h3 class="font-semibold mb-2 text-lg">🍽️ In-house Dining</h3>
          <p class="text-gray-400">Delicious meals available</p>
        </div>

      </div>
    </section>


    <!-- CTA -->
    <section class="px-6 py-20 text-center border-t border-gray-800">
      <h2 class="text-4xl font-bold mb-4">
        Book Your Stay Today 🛎️
      </h2>

      <p class="text-gray-400 mb-6">
        Limited rooms available. Reserve now for the best experience.
      </p>

      <a 
        href="https://wa.me/918473819569"
        class="bg-yellow-500 text-black px-8 py-4 rounded-xl font-semibold text-lg hover:bg-yellow-400 transition"
      >
        Book Now on WhatsApp
      </a>