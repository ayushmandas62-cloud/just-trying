---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ContentCard from '../../components/ContentCard.astro';

// Get all markdown files from content folder
const allContent = [
  {
    title: 'Why I Started Building in Public',
    description: 'My journey and reasons for sharing work openly on the internet.',
    pubDate: new Date('2026-03-15'),
    slug: 'building-in-public',
    tags: ['Personal', 'Strategy'],
  },
  {
    title: 'AI Tools for Small Business Automation',
    description: 'A practical guide to implementing AI automation in your small business without breaking the bank.',
    pubDate: new Date('2026-03-10'),
    slug: 'ai-tools-small-business',
    tags: ['AI', 'Business', 'Automation'],
  },
  {
    title: 'Local Marketing Experiments - Month 1',
    description: 'First month results from testing various local marketing strategies for small businesses.',
    pubDate: new Date('2026-03-01'),
    slug: 'local-marketing-month-1',
    tags: ['Marketing', 'Experiments'],
  },
  {
    title: 'Lessons from My First Business Failure',
    description: 'What I learned from my first venture that didn't work out and how it shaped my approach.',
    pubDate: new Date('2026-02-20'),
    slug: 'first-business-failure',
    tags: ['Business', 'Lessons'],
  },
  {
    title: 'The Future of AI in Content Creation',
    description: 'Exploring how AI is changing the landscape of content creation and what it means for creators.',
    pubDate: new Date('2026-02-15'),
    slug: 'ai-content-creation',
    tags: ['AI', 'Content', 'Future'],
  },
];

// Sort by date (newest first)
allContent.sort((a, b) => b.pubDate.getTime() - a.pubDate.getTime());
---

<Layout
  title="Content - Ayushman"
  description="Blog posts, notes, and ideas on business, AI, marketing, and startups."
>
  <Navbar />

  <main class="flex-1">
    <!-- Page Header -->
    <section class="max-w-4xl mx-auto px-6 py-20 border-b border-border">
      <h1 class="text-4xl font-bold text-text mb-4">Content</h1>
      <p class="text-muted text-lg max-w-2xl">
        Blog posts, notes, and ideas exploring business, AI, marketing,
        and startup adventures.
      </p>
    </section>

    <!-- Content List -->
    <section class="max-w-4xl mx-auto px-6 py-16">
      <div class="grid gap-6">
        {allContent.map((content) => (
          <ContentCard {...content} />
        ))}
      </div>
    </section>

    <!-- Newsletter CTA (placeholder) -->
    <section class="max-w-4xl mx-auto px-6 py-16 border-t border-border">
      <div class="text-center max-w-md mx-auto">
        <h2 class="text-xl font-semibold text-text mb-2">Stay Updated</h2>
        <p class="text-muted text-sm mb-4">
          Subscribe to get notified when I publish new content.
        </p>
        <a
          href="/contact"
          class="inline-block px-6 py-3 bg-text text-background font-medium rounded-lg hover:bg-muted transition-colors"
        >
          Subscribe
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
