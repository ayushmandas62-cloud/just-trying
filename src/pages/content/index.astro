---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ContentCard from '../../components/ContentCard.astro';

// Get all markdown files from content folder
const allContent = [
  
    {
    title: "Rice Bowl Guwahati Website",
    description: "Designed a restaurant website with WhatsApp ordering system to increase direct orders and reduce dependency on Zomato/Swiggy.",
    pubDate: new Date("2026-03-15"),
    slug: "rice-bowl",
    tags: ["Restaurant", "Website", "Conversion"],
    },
    {
    title: "For You Water Distribution Website",
    description: "Built a business website for a water supply service to generate B2B leads and showcase pricing & delivery model.",
    pubDate: new Date("2026-03-10"),
    slug: "water-distribution",
    tags: ["Business", "Logistics", "Lead Generation"],
    },
    {
    title: "PowerFit Gym Landing Page",
    description: "Created a high-converting landing page for gym membership signups using WhatsApp CTA.",
    pubDate: new Date("2026-03-05"),
    slug: "gym-landing",
    tags: ["Fitness", "Landing Page", "Conversion"],
    },
    {
    title: "Grand Stay Hotel Website",
    description: "Designed a hotel website with booking-focused UI to increase direct reservations and reduce OTA commissions.",
    pubDate: new Date("2026-03-01"),
    slug: "hotel-website",
    tags: ["Hotel", "Booking", "Business"],
    },
  ];

// Sort by date (newest first)
allContent.sort((a, b) => b.pubDate.getTime() - a.pubDate.getTime());
---

<Layout
  title="Content - Ayushman"
  description="Blog posts, notes, and ideas on business, AI, marketing, and startups."
>
  <Navbar />

  <main class="flex-1">
    <!-- Page Header -->
    <section class="max-w-4xl mx-auto px-6 py-20 border-b border-border">
      <h1 class="text-4xl font-bold text-text mb-4">
        Client Website Projects
      </h1>

      <p class="text-muted text-lg max-w-2xl">
      Real website concepts designed to help businesses get more customers and increase conversions.
      </p>
    </section>

    <!-- Content List -->
    <section class="max-w-4xl mx-auto px-6 py-16">
      <div class="grid gap-6">
        {allContent.map((content) => (
          <ContentCard {...content} />
        ))}
      </div>
    </section>

    <!-- Newsletter CTA (placeholder) -->
    <section class="max-w-4xl mx-auto px-6 py-16 border-t border-border">
      <div class="text-center max-w-md mx-auto">
        <h2 class="text-xl font-semibold text-text mb-2">Stay Updated</h2>
        <p class="text-muted text-sm mb-4">
          Subscribe to get notified when I publish new content.
        </p>
        <a
          href="/contact"
          class="inline-block px-6 py-3 bg-text text-background font-medium rounded-lg hover:bg-muted transition-colors"
        >
          Subscribe
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
