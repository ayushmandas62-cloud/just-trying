---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Page Not Found - Ayushman">
  <Navbar />

  <main class="flex-1 flex items-center justify-center">
    <div class="text-center px-6 py-20">
      <h1 class="text-6xl font-bold text-text mb-4">404</h1>
      <p class="text-xl text-muted mb-8">Page not found</p>
      <p class="text-muted mb-8">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <a
        href="/"
        class="inline-block px-6 py-3 bg-text text-background font-medium rounded-lg hover:bg-muted transition-colors"
      >
        Go Home
      </a>
    </div>
  </main>

  <Footer />
</Layout>
