---
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CareClinic - Premium Health Services</title>
    <style>
      /* Click Animation */
      .click-animate {
        transition: transform 0.15s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.15s;
      }
      .click-animate:active {
        transform: scale(0.95);
        box-shadow: none;
      }
      
      /* Fade Up Animation */
      .fade-in-up {
        animation: fadeInUp 0.8s ease-out forwards;
        opacity: 0;
        transform: translateY(20px);
      }
      @keyframes fadeInUp {
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .delay-100 { animation-delay: 100ms; }
      .delay-200 { animation-delay: 200ms; }
      .delay-300 { animation-delay: 300ms; }
    </style>
  </head>
  <body class="bg-slate-50 text-slate-900 font-sans antialiased overflow-x-hidden">
    
    <!-- AI Voice Chatbot Widget -->
    <div id="chatbot-container" class="fixed bottom-6 right-6 z-50 flex flex-col items-end">
      <!-- Chat Window (Hidden by default) -->
      <div id="chat-window" class="hidden bg-white rounded-2xl shadow-2xl w-80 md:w-96 border border-slate-200 overflow-hidden mb-4">
        <!-- Chat Header -->
        <div class="bg-blue-600 text-white px-5 py-4 flex items-center justify-between">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-white/20 rounded-full flex items-center justify-center relative">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"></path></svg>
              <!-- Voice indicator -->
              <span id="voice-indicator" class="absolute -top-1 -right-1 w-3 h-3 bg-green-500 rounded-full hidden animate-pulse"></span>
            </div>
            <div>
              <h3 class="font-bold">CareClinic AI Assistant</h3>
              <p class="text-xs text-blue-200">Voice & Chat • Ready to help</p>
            </div>
          </div>
          <button id="close-chat" class="text-white/80 hover:text-white transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
          </button>
        </div>
        
        <!-- Voice Status Bar -->
        <div id="voice-status" class="bg-gradient-to-r from-blue-50 to-indigo-50 px-4 py-3 border-b border-blue-100 hidden">
          <div class="flex items-center gap-3">
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 bg-red-500 rounded-full animate-pulse"></div>
              <span class="text-xs font-medium text-blue-800">Listening...</span>
            </div>
            <div class="flex-1 flex items-center justify-center gap-1">
              <div class="w-1 h-4 bg-blue-400 rounded-full animate-pulse" style="animation-delay: 0ms"></div>
              <div class="w-1 h-6 bg-blue-500 rounded-full animate-pulse" style="animation-delay: 100ms"></div>
              <div class="w-1 h-3 bg-blue-400 rounded-full animate-pulse" style="animation-delay: 200ms"></div>
              <div class="w-1 h-5 bg-blue-500 rounded-full animate-pulse" style="animation-delay: 300ms"></div>
              <div class="w-1 h-4 bg-blue-400 rounded-full animate-pulse" style="animation-delay: 400ms"></div>
              <div class="w-1 h-6 bg-blue-500 rounded-full animate-pulse" style="animation-delay: 500ms"></div>
              <div class="w-1 h-3 bg-blue-400 rounded-full animate-pulse" style="animation-delay: 600ms"></div>
            </div>
            <button id="stop-voice" class="text-blue-600 hover:text-blue-800 text-xs font-medium">Stop</button>
          </div>
        </div>
        
        <!-- Chat Messages -->
        <div id="chat-messages" class="h-56 overflow-y-auto p-4 space-y-4 bg-slate-50">
          <!-- Welcome Message -->
          <div class="flex gap-3">
            <div class="w-8 h-8 bg-blue-600 rounded-full flex-shrink-0 flex items-center justify-center text-white text-xs">AI</div>
            <div class="bg-white border border-slate-200 rounded-2xl rounded-tl-md p-3 text-sm text-slate-700 shadow-sm">
              Hello! 👋 I'm your AI assistant. You can type or <strong>use your voice</strong> to chat with me. How can I help you today?
              <div class="mt-3 flex flex-wrap gap-2">
                <button class="quick-reply bg-blue-50 text-blue-600 px-3 py-1.5 rounded-full text-xs font-medium hover:bg-blue-100 transition-colors" data-message="Book an appointment">Book an appointment</button>
                <button class="quick-reply bg-blue-50 text-blue-600 px-3 py-1.5 rounded-full text-xs font-medium hover:bg-blue-100 transition-colors" data-message="What services do you offer?">Our services</button>
                <button class="quick-reply bg-blue-50 text-blue-600 px-3 py-1.5 rounded-full text-xs font-medium hover:bg-blue-100 transition-colors" data-message="What are your timings?">Clinic hours</button>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Chat Input -->
        <div class="border-t border-slate-200 p-3 bg-white">
          <form id="chat-form" class="flex gap-2">
            <input type="text" id="chat-input" placeholder="Type your message..." class="flex-1 px-4 py-2 rounded-full border border-slate-200 focus:border-blue-600 focus:ring-2 focus:ring-blue-100 outline-none transition-all text-sm" />
            <button type="button" id="voice-btn" class="bg-indigo-100 text-indigo-600 w-10 h-10 rounded-full flex items-center justify-center hover:bg-indigo-200 transition-colors flex-shrink-0" title="Speak">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"></path></svg>
            </button>
            <button type="submit" class="bg-blue-600 text-white w-10 h-10 rounded-full flex items-center justify-center hover:bg-blue-700 transition-colors flex-shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path></svg>
            </button>
          </form>
        </div>
      </div>
      
      <!-- Chat Toggle Button -->
      <button id="chat-toggle" class="bg-blue-600 text-white w-14 h-14 rounded-full shadow-xl flex items-center justify-center hover:bg-blue-700 hover:scale-105 transition-all click-animate group">
        <svg id="chat-icon" class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
        <svg id="close-icon" class="w-7 h-7 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        <!-- Notification Badge -->
        <span id="chat-notification" class="absolute -top-1 -right-1 w-5 h-5 bg-red-500 rounded-full text-xs flex items-center justify-center font-bold">1</span>
      </button>
    </div>
    
    <!-- Top Bar -->
    <div class="bg-blue-600 text-white text-sm py-2 px-4 text-center font-medium">
      Emergency? Call us 24/7: <a href="tel:+1234567890" class="underline hover:text-blue-100 transition-colors">+1 (234) 567-890</a>
    </div>

    <!-- Navigation -->
    <nav class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-slate-200">
      <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
        <a href="#" class="text-2xl font-bold text-blue-600 flex items-center gap-2 click-animate">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
          CareClinic
        </a>
        <div class="hidden md:flex gap-8 font-medium text-slate-600">
          <a href="#services" class="hover:text-blue-600 transition-colors">Services</a>
          <a href="#about" class="hover:text-blue-600 transition-colors">About</a>
          <a href="#testimonials" class="hover:text-blue-600 transition-colors">Reviews</a>
        </div>
        <a href="#book" class="bg-blue-600 text-white px-6 py-2.5 rounded-full font-bold shadow-lg shadow-blue-200 hover:bg-blue-700 hover:shadow-xl hover:-translate-y-0.5 transition-all click-animate">
          Book Appointment
        </a>
      </div>
    </nav>

    <!-- Hero Section -->
    <section class="relative pt-20 pb-24 md:pt-32 md:pb-32 px-6 overflow-hidden">
      <!-- Background Decor -->
      <div class="absolute top-0 right-0 w-full h-full bg-gradient-to-br from-blue-50/50 to-white -z-10"></div>
      <div class="absolute top-20 right-10 w-[30rem] h-[30rem] bg-blue-100 rounded-full mix-blend-multiply filter blur-[100px] opacity-70 -z-10"></div>
      <div class="absolute bottom-10 left-10 w-[20rem] h-[20rem] bg-teal-50 rounded-full mix-blend-multiply filter blur-[80px] opacity-70 -z-10"></div>

      <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center">
        <!-- Hero Text -->
        <div class="max-w-xl fade-in-up">
          <span class="inline-flex items-center gap-2 py-1.5 px-4 rounded-full bg-blue-100 text-blue-700 font-semibold text-sm mb-6 border border-blue-200">
            <span class="w-2 h-2 rounded-full bg-blue-600 animate-pulse"></span>
            Accepting New Patients
          </span>
          <h1 class="text-5xl md:text-6xl font-extrabold leading-[1.1] mb-6 text-slate-900 tracking-tight">
            Expert Healthcare, <br/><span class="text-blue-600">Tailored for You.</span>
          </h1>
          <p class="text-lg md:text-xl text-slate-600 mb-8 leading-relaxed">
            Experience compassionate, world-class medical care. Skip the waiting lines and get treated by our top-rated specialists today.
          </p>
          
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#book" class="bg-blue-600 text-white text-center px-8 py-4 rounded-xl font-bold shadow-xl shadow-blue-200 hover:bg-blue-700 hover:-translate-y-1 transition-all click-animate flex items-center justify-center gap-2 text-lg">
              Book a Visit <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </a>
            <a href="https://wa.me/918473819569" target="_blank" class="bg-white text-slate-800 border-2 border-slate-200 text-center px-8 py-4 rounded-xl font-bold hover:border-green-500 hover:text-green-600 hover:-translate-y-1 transition-all click-animate flex items-center justify-center gap-2 text-lg shadow-sm hover:shadow-md">
              <svg class="w-6 h-6 text-green-500" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
              Chat on WhatsApp
            </a>
          </div>
          
          <!-- Trust Indicators -->
          <div class="mt-8 flex flex-wrap items-center gap-6 text-sm text-slate-600 font-medium">
            <div class="flex items-center gap-2">
              <div class="bg-green-100 p-1 rounded-full"><svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg></div>
              Top Specialists
            </div>
            <div class="flex items-center gap-2">
              <div class="bg-green-100 p-1 rounded-full"><svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg></div>
              No Hidden Fees
            </div>
          </div>
        </div>
        
        <!-- Hero Image -->
        <div class="relative hidden md:block fade-in-up delay-200">
          <div class="absolute inset-0 bg-blue-600 rounded-[2rem] transform translate-x-4 translate-y-4 opacity-10"></div>
          <img src="https://images.unsplash.com/photo-1638202993928-7267aad84c31?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Doctor smiling" class="rounded-[2rem] shadow-2xl object-cover h-[550px] w-full relative z-10" />
          
          <!-- Floating card -->
          <div class="absolute bottom-8 -left-8 bg-white p-5 rounded-2xl shadow-xl flex items-center gap-4 click-animate hover:-translate-y-2 transition-transform cursor-pointer z-20 border border-slate-100">
            <div class="bg-yellow-100 p-3 rounded-full text-yellow-500">
              <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
            </div>
            <div>
              <div class="font-bold text-slate-900 text-lg">4.9/5 Rating</div>
              <div class="text-sm text-slate-500">from 2,000+ patients</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Services / Features -->
    <section id="services" class="py-24 bg-white px-6">
      <div class="max-w-6xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Comprehensive Care <br/>Under One Roof</h2>
        <p class="text-slate-600 max-w-2xl mx-auto mb-16 text-lg">We offer a wide range of medical services to ensure you and your family receive the best possible care without multiple referrals.</p>
        
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
          <!-- Service Card 1 -->
          <div class="bg-slate-50 rounded-2xl p-8 border border-slate-100 hover:border-blue-200 hover:shadow-xl transition-all hover:-translate-y-2 click-animate text-left group">
            <div class="w-14 h-14 bg-blue-100 rounded-xl flex items-center justify-center text-blue-600 mb-6 group-hover:bg-blue-600 group-hover:text-white transition-colors">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-3">General Checkups</h3>
            <p class="text-slate-600 leading-relaxed mb-6">Routine examinations and preventive care to keep your health on track and catch issues early.</p>
            <a href="#book" class="text-blue-600 font-semibold inline-flex items-center gap-1 hover:gap-2 transition-all">Learn more <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg></a>
          </div>

          <!-- Service Card 2 -->
          <div class="bg-slate-50 rounded-2xl p-8 border border-slate-100 hover:border-blue-200 hover:shadow-xl transition-all hover:-translate-y-2 click-animate text-left group">
            <div class="w-14 h-14 bg-teal-100 rounded-xl flex items-center justify-center text-teal-600 mb-6 group-hover:bg-teal-600 group-hover:text-white transition-colors">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-3">Lab Tests</h3>
            <p class="text-slate-600 leading-relaxed mb-6">In-house laboratory for quick and accurate diagnostic tests, reducing your waiting time.</p>
            <a href="#book" class="text-teal-600 font-semibold inline-flex items-center gap-1 hover:gap-2 transition-all">Learn more <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg></a>
          </div>

          <!-- Service Card 3 -->
          <div class="bg-slate-50 rounded-2xl p-8 border border-slate-100 hover:border-blue-200 hover:shadow-xl transition-all hover:-translate-y-2 click-animate text-left group">
            <div class="w-14 h-14 bg-indigo-100 rounded-xl flex items-center justify-center text-indigo-600 mb-6 group-hover:bg-indigo-600 group-hover:text-white transition-colors">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-3">Pediatrics</h3>
            <p class="text-slate-600 leading-relaxed mb-6">Gentle and expert care for children of all ages in a friendly and welcoming environment.</p>
            <a href="#book" class="text-indigo-600 font-semibold inline-flex items-center gap-1 hover:gap-2 transition-all">Learn more <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg></a>
          </div>
        </div>
      </div>
    </section>

    <!-- Appointment CTA / High Conversion Form -->
    <section id="book" class="py-24 bg-blue-600 px-6 relative overflow-hidden">
      <!-- Decor -->
      <div class="absolute top-0 right-0 w-64 h-64 bg-white opacity-5 rounded-full -translate-y-1/2 translate-x-1/3"></div>
      <div class="absolute bottom-0 left-0 w-96 h-96 bg-white opacity-5 rounded-full translate-y-1/3 -translate-x-1/3"></div>

      <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-16 items-center relative z-10">
        <div class="text-white">
          <h2 class="text-4xl md:text-5xl font-bold mb-6">Ready to prioritize your health?</h2>
          <p class="text-blue-100 text-lg mb-10 leading-relaxed">Fill out the form to request an appointment. Our team will get back to you within 30 minutes to confirm your slot.</p>
          
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="bg-white/20 p-3 rounded-full mt-1">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              </div>
              <div>
                <h4 class="font-bold text-xl mb-1">Fast Response Time</h4>
                <p class="text-blue-100">We respect your time. Get confirmation quickly.</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="bg-white/20 p-3 rounded-full mt-1">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              </div>
              <div>
                <h4 class="font-bold text-xl mb-1">Or Call Us Directly</h4>
                <p class="text-blue-100">+1 (234) 567-890</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Conversion Form -->
        <div class="bg-white rounded-3xl p-8 md:p-10 shadow-2xl click-animate transition-transform hover:-translate-y-1">
          <h3 class="text-2xl font-bold text-slate-900 mb-6">Book an Appointment</h3>
          <form class="space-y-5" onsubmit="event.preventDefault(); alert('Appointment requested! We will contact you shortly.');">
            <div class="grid grid-cols-2 gap-5">
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">First Name</label>
                <input type="text" required class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-blue-600 focus:ring-2 focus:ring-blue-100 outline-none transition-all" placeholder="John">
              </div>
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-1">Last Name</label>
                <input type="text" required class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-blue-600 focus:ring-2 focus:ring-blue-100 outline-none transition-all" placeholder="Doe">
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1">Phone Number</label>
              <input type="tel" required class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-blue-600 focus:ring-2 focus:ring-blue-100 outline-none transition-all" placeholder="(123) 456-7890">
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1">Service Needed</label>
              <select class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-blue-600 focus:ring-2 focus:ring-blue-100 outline-none transition-all bg-white">
                <option>General Checkup</option>
                <option>Pediatrics</option>
                <option>Lab Tests</option>
                <option>Other</option>
              </select>
            </div>
            <button type="submit" class="w-full bg-blue-600 text-white font-bold text-lg py-4 rounded-xl shadow-lg shadow-blue-200 hover:bg-blue-700 hover:-translate-y-0.5 transition-all click-animate mt-2">
              Request Appointment
            </button>
            <p class="text-center text-xs text-slate-500 mt-4">Your information is secure and encrypted.</p>
          </form>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="bg-slate-900 text-slate-400 py-12 px-6">
      <div class="max-w-6xl mx-auto grid md:grid-cols-4 gap-8 mb-8 border-b border-slate-800 pb-8">
        <div class="col-span-2 md:col-span-1">
          <a href="#" class="text-2xl font-bold text-white flex items-center gap-2 mb-4">
            <svg class="w-6 h-6 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
            CareClinic
          </a>
          <p class="text-sm">Providing exceptional healthcare services with a patient-first approach.</p>
        </div>
        <div>
          <h4 class="text-white font-semibold mb-4">Quick Links</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="#" class="hover:text-white transition-colors">Home</a></li>
            <li><a href="#services" class="hover:text-white transition-colors">Services</a></li>
            <li><a href="#book" class="hover:text-white transition-colors">Book Appointment</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-white font-semibold mb-4">Contact</h4>
          <ul class="space-y-2 text-sm">
            <li>123 Medical Drive, NY 10001</li>
            <li>hello@careclinic.com</li>
            <li>+1 (234) 567-890</li>
          </ul>
        </div>
        <div>
          <h4 class="text-white font-semibold mb-4">Hours</h4>
          <ul class="space-y-2 text-sm">
            <li>Mon - Fri: 8am - 8pm</li>
            <li>Saturday: 9am - 5pm</li>
            <li>Sunday: Emergency Only</li>
          </ul>
        </div>
      </div>
      <div class="max-w-6xl mx-auto text-center text-sm">
        &copy; 2026 CareClinic. Designed to convert.
      </div>
    </footer>

  <script>
    // AI Voice Chatbot Logic
    document.addEventListener('DOMContentLoaded', function() {
      const chatToggle = document.getElementById('chat-toggle');
      const chatWindow = document.getElementById('chat-window');
      const closeChat = document.getElementById('close-chat');
      const chatForm = document.getElementById('chat-form');
      const chatInput = document.getElementById('chat-input');
      const chatMessages = document.getElementById('chat-messages');
      const chatIcon = document.getElementById('chat-icon');
      const closeIcon = document.getElementById('close-icon');
      const chatNotification = document.getElementById('chat-notification');
      const quickReplies = document.querySelectorAll('.quick-reply');
      const voiceBtn = document.getElementById('voice-btn');
      const voiceStatus = document.getElementById('voice-status');
      const stopVoiceBtn = document.getElementById('stop-voice');
      const voiceIndicator = document.getElementById('voice-indicator');
      
      let isChatOpen = false;
      let isListening = false;
      let recognition = null;
      let synth = window.speechSynthesis;
      
      // Check for speech recognition support
      const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
      if (SpeechRecognition) {
        recognition = new SpeechRecognition();
        recognition.continuous = false;
        recognition.interimResults = false;
        recognition.lang = 'en-US';
        
        recognition.onstart = function() {
          isListening = true;
          voiceStatus.classList.remove('hidden');
          voiceIndicator.classList.remove('hidden');
          voiceBtn.classList.add('bg-red-100', 'text-red-600');
          voiceBtn.classList.remove('bg-indigo-100', 'text-indigo-600');
        };
        
        recognition.onend = function() {
          isListening = false;
          voiceStatus.classList.add('hidden');
          voiceIndicator.classList.add('hidden');
          voiceBtn.classList.remove('bg-red-100', 'text-red-600');
          voiceBtn.classList.add('bg-indigo-100', 'text-indigo-600');
        };
        
        recognition.onresult = function(event) {
          const transcript = event.results[0][0].transcript;
          chatInput.value = transcript;
          addUserMessage(transcript);
          setTimeout(() => botReply(transcript), 600);
        };
        
        recognition.onerror = function(event) {
          console.error('Speech recognition error:', event.error);
          isListening = false;
          voiceStatus.classList.add('hidden');
          voiceIndicator.classList.add('hidden');
          voiceBtn.classList.remove('bg-red-100', 'text-red-600');
          voiceBtn.classList.add('bg-indigo-100', 'text-indigo-600');
          
          if (event.error === 'not-allowed') {
            addBotMessage("I'm sorry, but I need permission to access your microphone. Please allow microphone access in your browser settings to use voice chat. 🎤");
          }
        };
      }
      
      // Voice button click
      voiceBtn.addEventListener('click', function() {
        if (!recognition) {
          addBotMessage("Sorry, your browser doesn't support voice recognition. Please use Chrome or Edge for voice chat. 🎤");
          return;
        }
        
        if (isListening) {
          recognition.stop();
        } else {
          try {
            recognition.start();
          } catch (e) {
            console.error('Error starting recognition:', e);
          }
        }
      });
      
      // Stop voice button
      stopVoiceBtn.addEventListener('click', function() {
        if (recognition && isListening) {
          recognition.stop();
        }
      });
      
      // Text-to-speech function
      function speak(text) {
        if (synth.speaking) {
          synth.cancel();
        }
        
        const utterance = new SpeechSynthesisUtterance(text);
        utterance.lang = 'en-US';
        utterance.rate = 1;
        utterance.pitch = 1;
        utterance.volume = 1;
        
        // Try to use a female voice if available
        const voices = synth.getVoices();
        const femaleVoice = voices.find(voice => voice.name.includes('Female') || voice.name.includes('Google US English'));
        if (femaleVoice) {
          utterance.voice = femaleVoice;
        }
        
        synth.speak(utterance);
      }
      
      // Toggle chat window
      chatToggle.addEventListener('click', function() {
        isChatOpen = !isChatOpen;
        if (isChatOpen) {
          chatWindow.classList.remove('hidden');
          chatIcon.classList.add('hidden');
          closeIcon.classList.remove('hidden');
          chatNotification.style.display = 'none';
          chatInput.focus();
          
          // Greet with voice on first open
          if (!window.hasGreeted) {
            setTimeout(() => {
              speak("Hello! Welcome to CareClinic. I'm your AI assistant. How can I help you today?");
              window.hasGreeted = true;
            }, 500);
          }
        } else {
          chatWindow.classList.add('hidden');
          chatIcon.classList.remove('hidden');
          closeIcon.classList.add('hidden');
          if (synth.speaking) {
            synth.cancel();
          }
        }
      });
      
      // Close button
      closeChat.addEventListener('click', function() {
        isChatOpen = false;
        chatWindow.classList.add('hidden');
        chatIcon.classList.remove('hidden');
        closeIcon.classList.add('hidden');
        if (synth.speaking) {
          synth.cancel();
        }
      });
      
      // Quick reply buttons
      quickReplies.forEach(button => {
        button.addEventListener('click', function() {
          const message = this.getAttribute('data-message');
          addUserMessage(message);
          this.remove();
          setTimeout(() => botReply(message), 600);
        });
      });
      
      // Form submission
      chatForm.addEventListener('submit', function(e) {
        e.preventDefault();
        const message = chatInput.value.trim();
        if (message) {
          addUserMessage(message);
          chatInput.value = '';
          setTimeout(() => botReply(message), 600);
        }
      });
      
      // Add user message to chat
      function addUserMessage(message) {
        const messageDiv = document.createElement('div');
        messageDiv.className = 'flex gap-3 justify-end';
        messageDiv.innerHTML = `
          <div class="bg-blue-600 text-white rounded-2xl rounded-tr-md p-3 text-sm shadow-md max-w-[80%]">
            ${escapeHtml(message)}
          </div>
        `;
        chatMessages.appendChild(messageDiv);
        scrollToBottom();
      }
      
      // Bot reply logic
      function botReply(userMessage) {
        const lowerMessage = userMessage.toLowerCase();
        let reply = '';
        
        if (lowerMessage.includes('book') || lowerMessage.includes('appointment')) {
          reply = 'I can help you book an appointment! You can either fill out the booking form below, or I can connect you with our team. Would you like to book now?';
          setTimeout(() => {
            addBotMessage(reply);
            speak(reply);
            setTimeout(() => {
              const quickBook = document.createElement('div');
              quickBook.className = 'flex gap-3 justify-center mt-2';
              quickBook.innerHTML = `
                <a href="#book" class="bg-blue-600 text-white px-4 py-2 rounded-full text-xs font-medium hover:bg-blue-700 transition-colors inline-flex items-center gap-1">
                  Yes, book now <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                </a>
              `;
              chatMessages.appendChild(quickBook);
              scrollToBottom();
            }, 300);
          }, 300);
        } else if (lowerMessage.includes('service') || lowerMessage.includes('offer')) {
          reply = 'We offer a wide range of services including General Checkups, Lab Tests, Pediatrics, Pharmacy, and Dental Care. All under one roof! Which service are you interested in?';
          setTimeout(() => {
            addBotMessage(reply);
            speak(reply);
          }, 300);
        } else if (lowerMessage.includes('timing') || lowerMessage.includes('hour') || lowerMessage.includes('open')) {
          reply = 'Our clinic hours are: Monday through Friday 8am to 8pm, Saturday 9am to 5pm, and Sunday for Emergency Only. We are available 24/7 for emergencies!';
          setTimeout(() => {
            addBotMessage(reply);
            speak(reply);
          }, 300);
        } else if (lowerMessage.includes('price') || lowerMessage.includes('cost') || lowerMessage.includes('fee')) {
          reply = 'We offer transparent pricing with no hidden fees. Our consultation starts at $50. For specific pricing, I recommend booking an appointment and our team will provide a detailed quote based on your needs.';
          setTimeout(() => {
            addBotMessage(reply);
            speak(reply);
          }, 300);
        } else if (lowerMessage.includes('location') || lowerMessage.includes('address') || lowerMessage.includes('where')) {
          reply = 'We are located at 123 Medical Drive, NY 10001. Easy to reach with public transport and we have free parking available!';
          setTimeout(() => {
            addBotMessage(reply);
            speak(reply);
          }, 300);
        } else if (lowerMessage.includes('emergency') || lowerMessage.includes('urgent')) {
          reply = 'For emergencies, please call us immediately at +1 (234) 567-890 or go to the nearest emergency room. Our emergency line is available 24/7!';
          setTimeout(() => {
            addBotMessage(reply);
            speak(reply);
          }, 300);
        } else if (lowerMessage.includes('thank')) {
          reply = "You're welcome! Is there anything else I can help you with?";
          setTimeout(() => {
            addBotMessage(reply);
            speak(reply);
          }, 300);
        } else if (lowerMessage.includes('hello') || lowerMessage.includes('hi') || lowerMessage.includes('hey')) {
          reply = 'Hello! Welcome to CareClinic. How can I assist you today?';
          setTimeout(() => {
            addBotMessage(reply);
            speak(reply);
          }, 300);
        } else if (lowerMessage.includes('yes') || lowerMessage.includes('sure')) {
          reply = 'Great! Please scroll down to the booking form or click the "Book a Visit" button to schedule your appointment. Our team will confirm within 30 minutes!';
          setTimeout(() => {
            addBotMessage(reply);
            speak(reply);
          }, 300);
        } else {
          reply = 'I understand you are asking about "' + userMessage + '". Let me connect you with our team who can better assist you. In the meantime, you can also reach us at +1 (234) 567-890 or chat on WhatsApp.';
          setTimeout(() => {
            addBotMessage(reply);
            speak(reply);
          }, 300);
        }
      }
      
      // Add bot message to chat
      function addBotMessage(message) {
        const messageDiv = document.createElement('div');
        messageDiv.className = 'flex gap-3';
        messageDiv.innerHTML = `
          <div class="w-8 h-8 bg-blue-600 rounded-full flex-shrink-0 flex items-center justify-center text-white text-xs">AI</div>
          <div class="bg-white border border-slate-200 rounded-2xl rounded-tl-md p-3 text-sm text-slate-700 shadow-sm max-w-[85%] whitespace-pre-line">
            ${escapeHtml(message)}
          </div>
        `;
        chatMessages.appendChild(messageDiv);
        scrollToBottom();
      }
      
      // Scroll to bottom of chat
      function scrollToBottom() {
        chatMessages.scrollTop = chatMessages.scrollHeight;
      }
      
      // Escape HTML to prevent XSS
      function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
      }
      
      // Load voices for speech synthesis
      if (synth) {
        synth.onvoiceschanged = function() {
          synth.getVoices();
        };
      }
    });
  </script>
  </body>
</html>
